@using DigitalPreservation.Common.Model
@using DigitalPreservation.Common.Model.Transit.Combined
@using DigitalPreservation.Common.Model.Transit.Extensions
@model CombinedBase

<a class="link-primary mods-launcher" role="button" data-bs-toggle="modal" data-bs-target="#modsModal"
   aria-label="Set rights and access conditions"
   data-access="@string.Join(',', Model.AccessRestrictions)"
   data-eff-access="@string.Join(',', Model.EffectiveAccessRestrictions)"
   data-rights="@RightsStatement.GetShortLabel(Model.RightsStatement)"
   data-eff-rights="@RightsStatement.GetShortLabel(Model.EffectiveRightsStatement)"
   data-recordinfo="@Model.RecordInfo?.ToCompactString()"
   data-eff-recordinfo="@Model.EffectiveRecordInfo?.ToCompactString()"
>
    <svg class="bi"><use xlink:href="#info-square"/></svg>
</a>

@{
    // Collect display items as (label, text, inherited). Inherited items render in muted style.
    var items = new List<(string Label, string Text, bool Inherited)>();

    if (Model.AccessRestrictions.Count > 0)
    {
        if (!Model.EffectiveAccessRestrictions.SequenceEqual(Model.AccessRestrictions))
            throw new NotSupportedException("Effective access restrictions don't equal explicit access restrictions");
        items.Add(("Access", string.Join(", ", Model.AccessRestrictions), false));
    }
    else if (Model.EffectiveAccessRestrictions.Count > 0)
    {
        items.Add(("Access", string.Join(", ", Model.EffectiveAccessRestrictions), true));
    }

    if (Model.RightsStatement != null)
    {
        if (Model.EffectiveRightsStatement != Model.RightsStatement)
            throw new NotSupportedException("Effective rights statement does not equal explicit rights statement");
        items.Add(("Rights", RightsStatement.GetShortLabel(Model.RightsStatement) ?? "", false));
    }
    else if (Model.EffectiveRightsStatement != null)
    {
        items.Add(("Rights", RightsStatement.GetShortLabel(Model.EffectiveRightsStatement) ?? "", true));
    }

    if (Model.RecordInfo != null)
    {
        if (!Model.RecordInfo.HasSameIdentifiers(Model.EffectiveRecordInfo))
            throw new NotSupportedException("Effective record identifiers do not equal explicit record identifiers");
        items.Add(("Record", Model.RecordInfo.ToCompactString()?.Replace(RecordInfo.CompactDelimiter, ", ") ?? "", false));
    }
    else if (Model.EffectiveRecordInfo != null)
    {
        items.Add(("Record", Model.EffectiveRecordInfo.ToCompactString()?.Replace(RecordInfo.CompactDelimiter, ", ") ?? "", true));
    }
}

@for (var i = 0; i < items.Count; i++)
{
    if (i > 0) { <span>; </span> }
    var item = items[i];
    <small class="@(item.Inherited ? "text-secondary" : "")">@item.Label: <em><strong>@item.Text</strong></em></small>
}
