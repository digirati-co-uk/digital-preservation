{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "HealthChecks": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3} {SourceContext} {CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Storage-AWS": {
    "Region": "eu-west-1"
  },
  "AwsStorage": {
    "DefaultWorkingBucket": "dev-deposits",
    "S3HealthCheckKey": "checks/test.json"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/"
  },
  "FeatureFlags": {
    "DisableAuth": "false"
  },
  "IdentityService": {
    "Root": "https://id.library.leeds.ac.uk",
    "TimeoutMs": 5000,
    "ApiKeyHeader": "X-API-KEY"
  },
  "AccessConditions": [
    { "Value": "dlip-0-open",       "Label": "Open 0" },
    { "Value": "dlip-1-open",       "Label": "Open 1" },
    { "Value": "dlip-2-restricted", "Label": "Restricted" },
    { "Value": "dlip-3-protected",  "Label": "Protected" },
    { "Value": "dlip-4-closed",     "Label": "Closed" },
    { "Value": "dlip-unassessed",   "Label": "Unassessed" }
  ]
}
